# Optional override: full backend base URL (rarely needed).
# If set, this wins over tenant-derived base URL.
# Example: VITE_API_BASE_URL=http://company1.localhost:8000
# VITE_API_BASE_URL=

# Backend port when frontend runs on a different port.
# The tenant subdomain is still derived from window.location.hostname.
VITE_API_PORT=8000

